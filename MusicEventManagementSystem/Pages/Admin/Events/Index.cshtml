@page
@model MusicEventManagementSystem.Pages.Admin.Events.IndexModel
@{
    ViewData["Title"] = "Event Management";
}

<h1>Event Management</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Event</a>
</p>

<table class="table table-striped table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Published</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.MusicEvents)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.EventName)</td>
                <td>@Html.DisplayFor(modelItem => item.Location)</td>
                <td>@Html.DisplayFor(modelItem => item.EventDate)</td>
                <td>@Html.DisplayFor(modelItem => item.EndDate)</td>
                <td>@Html.DisplayFor(modelItem => item.IsPublished)</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.EventID" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-page="./Delete" asp-route-id="@item.EventID" class="btn btn-sm btn-outline-danger">Delete</a>
                    <a asp-page="/Events/Detail" asp-route-id="@item.EventID" class="btn btn-sm btn-outline-info" target="_blank">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>