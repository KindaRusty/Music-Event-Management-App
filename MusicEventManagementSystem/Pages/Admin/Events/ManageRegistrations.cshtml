@page "{id:int?}"
@model MusicEventManagementSystem.Pages.Admin.Events.ManageRegistrationsModel
@{
    ViewData["Title"] = "Manage Registrations";
}

<h2>Manage Registrations for: @Model.MusicEvent.EventName</h2>
<hr />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">

    <div class="col-md-5">
        <div class="card my-4 shadow-sm">
            <div class="card-header">Send Bulk Notification</div>
            <div class="card-body">
                <form method="post" asp-page-handler="SendTemplatedEmail" asp-route-id="@Model.MusicEvent.EventID">

                    <div class="form-group mb-3">
                        <label asp-for="SelectedTemplate" class="form-label">Select Email Template</label>
                        <select asp-for="SelectedTemplate" class="form-select">
                            <option value="Custom">1. Custom (Send raw content)</option>
                            <option value="EventAnnouncement">2. "Event Announcement" Template</option>
                        </select>
                        <small class="form-text text-muted">
                            If "Event Announcement" is selected, the content below will be inserted into the template.
                        </small>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="EmailSubject" class="form-label">Subject</label>
                        <input asp-for="EmailSubject" class="form-control" />
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="AiPrompt" class="form-label">AI Prompt (Optional)</label>
                        <div class="input-group">
                            <input asp-for="AiPrompt" class="form-control" placeholder="e.g., Write an event postponement notice..." />
                            <button class="btn btn-info" type="button" id="btnGenerateAiContent">Generate (AI)</button>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="EmailMessage" class="form-label">Message Content</label>
                        <textarea asp-for="EmailMessage" class="form-control" rows="8" id="EmailMessageContent"></textarea>
                    </div>

                    <button type="submit" class="btn btn-warning w-100">Send to All Attendees</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="my-4">
            <h3>Attendee List (@Model.Registrations.Count)</h3>
            <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                <table class="table table-striped table-hover">
                    <thead class="table-dark" style="position: sticky; top: 0;">
                        <tr>
                            <th>User Email</th>
                            <th>Ticket Tier Name</th>
                            <th>Quantity</th>
                            <th>Total</th>
                            <th>Registration Date</th>
                            <th>Payment</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reg in Model.Registrations.OrderBy(r => r.RegistrationDate))
                        {
                            <tr>
                                <td>@reg.ApplicationUser?.Email</td>
                                <td>@reg.PricingTier?.TierName</td>
                                <td>
                                    @if (reg.PricingTier != null && reg.PricingTier.Price > 0)
                                    {
                                        @Math.Round(reg.TotalPrice / reg.PricingTier.Price)
                                    }
                                    else
                                    {
                                        @(reg.TotalPrice == 0 ? 1 : "N/A")
                                    }
                                </td>
                                <td>@reg.TotalPrice.ToString("N0") VND</td>
                                <td>@reg.RegistrationDate.ToString("g")</td>
                                <td>
                                    @if (reg.PaymentStatus == "Paid")
                                    {
                                        <span class="badge bg-success">@reg.PaymentStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@reg.PaymentStatus</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
<div>
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Event List
    </a>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#btnGenerateAiContent').click(function() {
                var prompt = $('#AiPrompt').val();
                var eventName = '@Html.Raw(System.Text.Json.JsonEncodedText.Encode(Model.MusicEvent.EventName))'; // Prevent JS errors

                if (!prompt) {
                    alert('Please enter a prompt for the AI.');
                    return;
                }

                $(this).prop('disabled', true).text('Generating...');
                var antiforgeryToken = $('input[name="__RequestVerificationToken"]').val();

                fetch('/Admin/Events/ManageRegistrations?handler=GenerateAiContent', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: JSON.stringify({
                        Prompt: prompt,
                        EventName: eventName
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if(data.success) {
                        $('#EmailMessageContent').val(data.content);
                    } else {
                        alert('Error: ' + data.error);
                    }
                    $(this).prop('disabled', false).text('Generate (AI)');
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while calling the AI.');
                    $(this).prop('disabled', false).text('Generate (AI)');
                });
            });
        });
    </script>
}