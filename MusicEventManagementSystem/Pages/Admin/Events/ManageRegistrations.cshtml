@page "{id:int?}"
@model MusicEventManagementSystem.Pages.Admin.Events.ManageRegistrationsModel
@{
    ViewData["Title"] = "Quản lý Đăng ký";
}

<h2>Quản lý Đăng ký cho: @Model.MusicEvent.EventName</h2>
<hr />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">

    <div class="col-md-5">
        <div class="card my-4 shadow-sm">
            <div class="card-header">Gửi Thông Báo Hàng Loạt</div>
            <div class="card-body">
                <form method="post" asp-page-handler="SendTemplatedEmail" asp-route-id="@Model.MusicEvent.EventID">

                    <div class="form-group mb-3">
                        <label asp-for="SelectedTemplate" class="form-label">Chọn Mẫu Email</label>
                        <select asp-for="SelectedTemplate" class="form-select">
                            <option value="Custom">1. Tùy chỉnh (Gửi nội dung thô)</option>
                            <option value="EventAnnouncement">2. Mẫu "Thông báo sự kiện"</option>
                        </select>
                        <small class="form-text text-muted">
                            Nếu chọn "Thông báo sự kiện", nội dung bên dưới sẽ được chèn vào giữa mẫu.
                        </small>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="EmailSubject" class="form-label">Chủ đề</label>
                        <input asp-for="EmailSubject" class="form-control" />
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="AiPrompt" class="form-label">Hướng dẫn AI (Tùy chọn)</label>
                        <div class="input-group">
                            <input asp-for="AiPrompt" class="form-control" placeholder="VD: Viết thông báo hoãn sự kiện..." />
                            <button class="btn btn-info" type="button" id="btnGenerateAiContent">Tạo (AI)</button>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="EmailMessage" class="form-label">Nội dung</label>
                        <textarea asp-for="EmailMessage" class="form-control" rows="8" id="EmailMessageContent"></textarea>
                    </div>

                    <button type="submit" class="btn btn-warning w-100">Gửi cho Tất cả Người tham dự</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="my-4">
            <h3>Danh sách người tham dự (@Model.Registrations.Count)</h3>
            <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                <table class="table table-striped table-hover">
                    <thead class="table-dark" style="position: sticky; top: 0;">
                        <tr>
                            <th>Email Người dùng</th>
                            <th>Tên Loại Vé</th>
                            <th>Số lượng</th>
                            <th>Tổng cộng</th>
                            <th>Ngày Đăng ký</th>
                            <th>Thanh toán</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reg in Model.Registrations.OrderBy(r => r.RegistrationDate))
                        {
                            <tr>
                                <td>@reg.ApplicationUser?.Email</td>
                                <td>@reg.PricingTier?.TierName</td>
                                <td>
                                    @if (reg.PricingTier != null && reg.PricingTier.Price > 0)
                                    {
                                        @Math.Round(reg.TotalPrice / reg.PricingTier.Price)
                                    }
                                    else
                                    {
                                        @(reg.TotalPrice == 0 ? 1 : "N/A")
                                    }
                                </td>
                                <td>@reg.TotalPrice.ToString("N0") VNĐ</td>
                                <td>@reg.RegistrationDate.ToString("g")</td>
                                <td>
                                    @if (reg.PaymentStatus == "Paid")
                                    {
                                        <span class="badge bg-success">@reg.PaymentStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@reg.PaymentStatus</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
<div>
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại Danh sách Sự kiện
    </a>
</div>

@section Scripts {
    <script>
        // Code JQuery cho nút AI của bạn vẫn giữ nguyên
        $(document).ready(function() {
            $('#btnGenerateAiContent').click(function() {
                var prompt = $('#AiPrompt').val();
                var eventName = '@Html.Raw(System.Text.Json.JsonEncodedText.Encode(Model.MusicEvent.EventName))'; // Chống lỗi JS

                if (!prompt) {
                    alert('Vui lòng nhập hướng dẫn cho AI.');
                    return;
                }

                $(this).prop('disabled', true).text('Đang tạo...');
                var antiforgeryToken = $('input[name="__RequestVerificationToken"]').val();

                fetch('/Admin/Events/ManageRegistrations?handler=GenerateAiContent', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: JSON.stringify({
                        Prompt: prompt,
                        EventName: eventName
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if(data.success) {
                        $('#EmailMessageContent').val(data.content);
                    } else {
                        alert('Lỗi: ' + data.error);
                    }
                    $(this).prop('disabled', false).text('Tạo (AI)');
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Đã xảy ra lỗi khi gọi AI.');
                    $(this).prop('disabled', false).text('Tạo (AI)');
                });
            });
        });
    </script>
}