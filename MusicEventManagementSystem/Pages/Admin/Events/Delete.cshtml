@page
@model MusicEventManagementSystem.Pages.Admin.Events.DeleteModel
@{
    ViewData["Title"] = "Delete Event";
}

<h1>Delete Event</h1>

<h3 class="text-danger">Are you sure you want to delete this event?</h3>
<div>
    <h4>@Model.MusicEvent.EventName</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.MusicEvent.EventName)</dd>

        <dt class="col-sm-3">Location</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.MusicEvent.Location)</dd>

        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.MusicEvent.EventDate)</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9" style="white-space: pre-wrap;">@Html.DisplayFor(model => model.MusicEvent.Description)</dd>
    </dl>

    <form method="post">
        @* Fix: Use EventID *@
        <input type="hidden" asp-for="MusicEvent.EventID" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Cancel (Back to List)</a>
    </form>
</div>