@page
@model MusicEventManagementSystem.Pages.User.MyEventsModel
@{
    ViewData["Title"] = "My Events";
}

<h1>My Events</h1>
<p>These are all the events you have registered for.</p>
<hr />

@if (!Model.MyRegistrations.Any())
{
    <p>You have not registered for any events. <a asp-page="/Index">View event list</a>.</p>
}
else
{
    <div class="row">
        @foreach (var reg in Model.MyRegistrations)
        {
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header">
                        <strong>@reg.MusicEvent?.EventName</strong>
                    </div>
                    <div class="card-body">
                        <p><strong>Date:</strong> @reg.MusicEvent?.EventDate.ToString("D")</p>
                        <p><strong>Location:</strong> @reg.MusicEvent?.Location</p>
                        <p>
                            <strong>Your Registration:</strong>
                            <br />
                            Ticket Type: @reg.PricingTier?.TierName
                            <br />
                            Quantity:
                            @if (reg.PricingTier != null && reg.PricingTier.Price > 0)
                            {
                                @Math.Round(reg.TotalPrice / reg.PricingTier.Price)
                            }
                            else
                            {
                                @(reg.TotalPrice == 0 ? 1 : "N/A")
                            }
                            <br />
                            Total: @reg.TotalPrice.ToString("C")
                            <br />
                            Registration Date: @reg.RegistrationDate.ToString("g")
                        </p>
                        <a asp-page="/Events/Details" asp-route-id="@reg.EventID" class="btn btn-info">View Event Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}