@page
@model MusicEventManagementSystem.Pages.Users.MyEventsModel
@{
    ViewData["Title"] = "My Registered Events";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>
    <hr />

    @if (Model.Registrations.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Event</th>
                        <th>Ticket Type</th>
                        <th>Registration Date</th>
                        <th>Payment Status</th>
                        <th>Event Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in Model.Registrations)
                    {
                        string eventStatus;
                        string statusClass;
                        var now = DateTime.UtcNow;

                        if (reg.MusicEvent.EndDate.HasValue && reg.MusicEvent.EndDate < now)
                        {
                            eventStatus = "Ended";
                            statusClass = "badge bg-secondary";
                        }
                        else if (reg.MusicEvent.EventDate > now)
                        {
                            eventStatus = "Upcoming";
                            statusClass = "badge bg-primary";
                        }
                        else
                        {
                            eventStatus = "Ongoing/Past";
                            statusClass = "badge bg-info";
                            if (reg.MusicEvent.EventDate < now.AddDays(-1) && !reg.MusicEvent.EndDate.HasValue)
                            {
                                eventStatus = "Ended";
                                statusClass = "badge bg-secondary";
                            }
                        }

                        <tr>
                            <td>
                                <strong>@reg.MusicEvent.EventName</strong><br>
                                <small class="text-muted">@reg.MusicEvent.Location</small>
                            </td>
                            <td>@reg.PricingTier.TierName</td>
                            <td>@reg.RegistrationDate.ToString("g")</td>
                            <td>
                                @if (reg.PaymentStatus == "Confirmed")
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Unpaid</span>
                                }
                            </td>

                            <td>
                                <span class="@statusClass">@eventStatus</span>

                                @if (eventStatus == "Upcoming")
                                {
                                    <br>
                                    <small class="text-muted event-countdown"
                                           data-event-date="@reg.MusicEvent.EventDate.ToString("o")">
                                    </small>
                                }
                            </td>

                            <td>
                                <a asp-page="./TicketDetails" asp-route-id="@reg.RegistrationID" class="btn btn-sm btn-outline-primary">
                                    View Ticket
                                </a>
                                <a asp-page="/Events/Details" asp-route-id="@reg.EventID" class="btn btn-sm btn-outline-secondary">
                                    Event Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            You have not registered for any events yet.
        </div>
    }
</div>

@section Scripts {
    <script>
        // Run script when page is loaded
        document.addEventListener("DOMContentLoaded", function() {
            // 1. Find all countdown elements
            const countdownElements = document.querySelectorAll(".event-countdown");
            // 2. Get today's date (once) and set to 00:00
            const now = new Date();
            now.setHours(0, 0, 0, 0);
            // 3. Loop through each element
            countdownElements.forEach(function(element) {
                const eventDateString = element.getAttribute("data-event-date");
                if (!eventDateString) return;
                // 4. Parse event date and set to 00:00
                const eventDate = new Date(eventDateString);
                eventDate.setHours(0, 0, 0, 0);
                // 5. Calculate difference (in milliseconds)
                const diffTime = eventDate - now;
                // 6. Convert to days and round
                const diffDays = Math.round(diffTime / (1000 * 60 * 60 * 24));
                // 7. Show notification
                if (diffDays > 1) {
                    element.textContent = `(${diffDays} days remaining)`;
                } else if (diffDays === 1) {
                    element.textContent = `(Tomorrow)`;
                } else if (diffDays === 0) {
                    element.textContent = `(Today)`;
                }
            });
        });
    </script>
}