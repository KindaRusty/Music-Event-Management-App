@page "{id:int}"
@model MusicEventManagementSystem.Pages.Events.RegistrationSuccessModel
@{
    ViewData["Title"] = "Registration Successful";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-success">
                <div class="card-header bg-success text-white text-center">
                    <h2 class="mb-0">Registration Successful!</h2>
                </div>
                <div class="card-body p-4 p-md-5">
                    <p class="lead text-center">
                        Thank you for registering for the event.
                        Your details have been recorded.
                    </p>

                    <hr class="my-4">

                    <h4 class="mb-3">Registration Details</h4>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Event:</strong>
                            <span>@Model.Registration.MusicEvent.EventName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Registered Email:</strong>
                            <span>@Model.Registration.ApplicationUser.Email</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Ticket Type:</strong>
                            <span>@Model.Registration.PricingTier.TierName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Quantity:</strong>
                            @if (Model.Registration.PricingTier.Price > 0)
                            {
                                <span>@Math.Round(Model.Registration.TotalPrice / Model.Registration.PricingTier.Price)</span>
                            }
                            else
                            {
                                <span>1</span>
                            }
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Total:</strong>
                            <strong>@Model.Registration.TotalPrice.ToString("C")</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Status:</strong>
                            <span class="badge bg-info text-dark">@Model.Registration.Status</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>Payment:</strong>
                            <span class="badge bg-warning text-dark">@Model.Registration.PaymentStatus.ToUpper()</span>
                        </li>
                    </ul>

                    @if (Model.DynamicData.Any())
                    {
                        <h5 class="mb-3">Information You Provided</h5>
                        <ul class="list-group list-group-flush">
                            @foreach (var data in Model.DynamicData)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <strong>@data.RequiredField.FieldName:</strong>
                                    @if (data.RequiredField.FieldType == "Checkbox")
                                    {
                                        <span>@(data.FieldValue == "true" ? "Agreed" : "No")</span>
                                    }
                                    else
                                    {
                                        <span>@data.FieldValue</span>
                                    }
                                </li>
                            }
                        </ul>
                    }

                    <hr class="my-4">

                    <div class="text-center d-grid gap-2 d-md-block">
                        <a asp-page="/Index" class="btn btn-primary btn-lg">Back to Home</a>
                        <a asp-page="/Users/MyEvents" class="btn btn-outline-secondary btn-lg">Manage Registrations</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>