@page "{id:int}"
@model MusicEventManagementSystem.Pages.Events.DetailModel
@{
    ViewData["Title"] = Model.MusicEvent.EventName;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.MusicEvent.ImageUrl))
            {
                <img src="@Model.MusicEvent.ImageUrl" class="img-fluid rounded shadow" alt="@Model.MusicEvent.EventName">
            }
            else
            {
                <img src="https://via.placeholder.com/600x400.png?text=Event+Image" class="img-fluid rounded shadow" alt="No Image Available">
            }
        </div>

        <div class="col-md-6">
            <h1 class="display-5">@Model.MusicEvent.EventName</h1>
            <hr />

            <div class="card bg-light mb-3">
                <div class="card-body">
                    <h5 class="card-title">Event Details</h5>
                    <p class="card-text">
                        <strong><i class="fas fa-calendar-alt"></i> Date:</strong>
                        @Model.MusicEvent.EventDate.ToString("dddd, MMMM dd, yyyy")

                        @* Fix: Check HasValue and use .Value *@
                        @if (Model.MusicEvent.EndDate.HasValue && Model.MusicEvent.EndDate.Value.Date == Model.MusicEvent.EventDate.Date)
                        {
                            <span> @Model.MusicEvent.EventDate.ToString("h:mm tt")</span>
                        }
                        else
                        {
                            <span> @Model.MusicEvent.EventDate.ToString("h:mm tt")</span>
                        }

                        @* Fix: Check HasValue and use .Value *@
                        @if (Model.MusicEvent.EndDate.HasValue)
                        {
                            <span> - @Model.MusicEvent.EndDate.Value.ToString("h:mm tt")</span>
                        }
                    </p>
                    <p class="card-text">
                        <strong><i class="fas fa-map-marker-alt"></i> Location:</strong>
                        @Model.MusicEvent.Location
                    </p>
                    @if (!string.IsNullOrEmpty(Model.MusicEvent.Genre))
                    {
                        <p class="card-text">
                            <strong><i class="fas fa-music"></i> Genre:</strong>
                            @Model.MusicEvent.Genre
                        </p>
                    }
                </div>
            </div>

            <div class="col-md-6">
                <div class="d-grid gap-2 mt-4">
                    @if (Model.IsAlreadyRegistered)
                    {
                        <a asp-page="/Users/TicketDetails" asp-route-id="@Model.UserRegistrationId" class="btn btn-info btn-lg">View Your Ticket</a>
                    }
                    else if (Model.IsEventOver)
                    {
                        <a class="btn btn-secondary btn-lg disabled" aria-disabled="true">Event Has Ended</a>
                    }
                    else if (Model.IsRegistrationClosed)
                    {
                        <a class="btn btn-warning btn-lg disabled" aria-disabled="true">Registration Closed</a>
                    }
                    else
                    {
                        <a asp-page="./Register" asp-route-id="@Model.MusicEvent.EventID" class="btn btn-success btn-lg">Register for this Event</a>
                    }
                </div>
                <a asp-page="/Index" class="btn btn-outline-secondary mt-3">
                    <i class="fas fa-arrow-left"></i> Back to all events
                </a>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <h2>About This Event</h2>
            <p style="white-space: pre-wrap; font-size: 1.1rem;">@Model.MusicEvent.Description</p>
        </div>
    </div>
</div>