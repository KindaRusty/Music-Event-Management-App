@page "{id:int}"
@model MusicEventManagementSystem.Pages.Events.RegisterModel
@{
    ViewData["Title"] = "Register for Event";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg">
                <div class="card-header bg-dark text-white">
                    <h2 class="mb-0">Register to Attend</h2>
                    <h4 class="mb-0 text-muted">@Model.MusicEvent.EventName</h4>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Input.EventID" />

                    <div class="card-body">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <h5 class="mb-3">Step 1: Select Ticket Type</h5>
                        <div class="mb-3">
                            @foreach (var tier in Model.MusicEvent.PricingTiers)
                            {
                                // Calculate remaining tickets
                                var remainingTickets = (tier.AvailableTickets.HasValue)
                                ? (tier.AvailableTickets - tier.SoldTickets)
                                : (int?)null;

                                bool isSoldOut = remainingTickets.HasValue && remainingTickets.Value <= 0;

                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio"
                                           asp-for="Input.PricingTierID"
                                           value="@tier.PricingTierID"
                                           id="tier-@tier.PricingTierID"
                                           disabled="@isSoldOut" />

                                    <label class="form-check-label" for="tier-@tier.PricingTierID">
                                        <strong>@tier.TierName (@tier.Price.ToString("C"))</strong>

                                        @if (isSoldOut)
                                        {
                                            <span class="badge bg-danger ms-2">SOLD OUT</span>
                                        }
                                        else if (remainingTickets.HasValue)
                                        {
                                            <span class="badge bg-warning ms-2">Only @remainingTickets tickets left</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success ms-2">Available</span>
                                        }
                                    </label>

                                    @if (tier.Description != null)
                                    {
                                        <small class="form-text text-muted d-block ms-4">@tier.Description</small>
                                    }
                                </div>
                            }
                            <span asp-validation-for="Input.PricingTierID" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 col-md-4">
                            <label asp-for="Input.Quantity" class="form-label">Quantity</label>
                            <select asp-for="Input.Quantity" class="form-select">
                                <option value="0">0 (Do not purchase)</option>
                                @* Note: This logic assumes a user can select a ticket type but quantity 0. 
                                   A better UX might be to only show quantity if a tier is selected via JS.
                                   For now, we'll assume a max of 10 or remaining. *@
                                @{
                                    var selectedTierForQty = Model.MusicEvent.PricingTiers.FirstOrDefault(t => t.PricingTierID == Model.Input.PricingTierID);
                                    var remainingForSelected = (selectedTierForQty?.AvailableTickets.HasValue ?? false)
                                    ? (selectedTierForQty.AvailableTickets - selectedTierForQty.SoldTickets)
                                    : 10; // Default max if no specific tier or unlimited
                                }
                                @for (int i = 1; i <= Math.Min(remainingForSelected ?? 10, 10); i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                            <span asp-validation-for="Input.Quantity" class="text-danger small"></span>
                        </div>

                        <hr class="my-4" />

                        <h5 class="mt-4 mb-3">Step 2: Your Information</h5>

                        @foreach (var field in Model.MusicEvent.RequiredFields.OrderBy(f => f.DisplayOrder))
                        {
                            switch (field.FieldType)
                            {
                                case "Checkbox":
                                    <div class="form-check mb-3">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               asp-for="Input.DynamicData[field.FieldID]"
                                               value="true"
                                               id="field-@field.FieldID" />
                                        <label class="form-check-label" for="field-@field.FieldID">@field.FieldName @(field.IsRequired ? "*" : "")</label>
                                        <input type="hidden" asp-for="Input.DynamicData[field.FieldID]" value="false" />
                                        <span asp-validation-for="Input.DynamicData[field.FieldID]" class="text-danger small"></span>
                                    </div>
                                    break;

                                case "Email":
                                case "Tel":
                                default: // "Text"
                                         <div class="form-floating mb-3">
                                             <input type="@field.FieldType.ToLower()"
                                                    class="form-control"
                                                    asp-for="Input.DynamicData[field.FieldID]"
                                                    id="field-@field.FieldID"
                                                    placeholder="@field.FieldName" />
                                             <label for="field-@field.FieldID">@field.FieldName @(field.IsRequired ? "*" : "")</label>
                                             <span asp-validation-for="Input.DynamicData[field.FieldID]" class="text-danger small"></span>
                                         </div>
                                    break;
                            }
                        }

                    </div>

                    <div class="card-footer d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">Confirm Registration</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}